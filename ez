#!/usr/bin/env python3

import os
import sys
import shutil
import subprocess
import platform
import argparse
import tarfile
import urllib.request

from pathlib import Path
from typing import Sequence

CWD = Path.cwd()
SYSTEM = platform.system()

BUILD_DIR = CWD / "build"
DIST_DIR = CWD / "dist"
BINARY_NAME = "osu-stuff"
IS_CI = os.environ.get("GITHUB_ACTIONS") == "true"
SDL_PKG_CONFIG_NAME = "sdl3"

TEST_DATA_URL = "https://github.com/mezleca/osu-stuff/releases/download/beatmaps/data.tar.gz"
TESTS_BUILD_DIR = BUILD_DIR / "tests"
TEST_DATA_CACHE_DIR = TESTS_BUILD_DIR / "test-data"

FLATPAK_BUILD_DIR = DIST_DIR / "flatpak-build"
FLATPAK_REPO_DIR = DIST_DIR / "flatpak-repo"
FLATPAK_STATE_DIR = DIST_DIR / ".flatpak-builder"
FLATPAK_BUNDLE_PATH = DIST_DIR / "osu-stuff.flatpak"
FLATPAK_APP_ID = "org.mezleca.osu-stuff"
FLATPAK_MANIFEST_PATH = CWD / "flatpak" / f"{FLATPAK_APP_ID}.yml"

def run(cmd: str | Sequence[str], check: bool = True, env: dict | None = None, capture: bool = False) -> tuple[int, str]:
    display = cmd if isinstance(cmd, str) else subprocess.list2cmdline(list(cmd))
    print(f"exec: {display}")
    result = subprocess.run(
        cmd,
        shell=isinstance(cmd, str),
        env=env,
        capture_output=capture,
        text=capture,
        encoding="utf-8",
        cwd=str(CWD)
    )

    if check and result.returncode != 0:
        print(f"[ez] command failed with exit code {result.returncode}")
        sys.exit(result.returncode)

    return result.returncode, result.stdout or ""

def tool_exists(tool: str) -> None:
    if shutil.which(tool) is None:
        raise Exception(f"{tool} not found in PATH")

def get_cpu_count() -> int:
    if SYSTEM == "Linux":
        result = subprocess.run("nproc", shell=True, capture_output=True, text=True)
        cores = result.stdout.strip()
        return int(cores) if cores.isdigit() else os.cpu_count() or 4
    return os.cpu_count() or 4

def has_system_sdl3() -> bool:
    if SYSTEM != "Linux":
        return False

    if shutil.which("pkg-config") is None:
        return False

    result = subprocess.run(
        ["pkg-config", "--exists", SDL_PKG_CONFIG_NAME],
        cwd=str(CWD),
    )
    return result.returncode == 0

def should_use_vendored_sdl(target_platform: str) -> bool:
    if target_platform == "windows":
        return True

    if target_platform == "linux":
        return not has_system_sdl3()

    if SYSTEM == "Windows":
        return True

    if SYSTEM == "Linux":
        return not has_system_sdl3()

    return False

def build_configure_cmd(build_type: str, build_tests: bool = False, use_vendored_sdl: bool = False) -> list[str]:
    cmake_type = "Debug" if build_type == "debug" else "Release"
    cmd = [
        "cmake",
        "-Wno-author", "-Wunused-variable", "-Wunused-function", "-Wunused-lambda-capture",
        "-Wdeprecated-copy-with-user-provided-copy", "-Wunused-lambda-capture",
        "-G", "Ninja",
        "-B", str(BUILD_DIR),
        "-S", str(CWD),
        "-DREALM_NO_TESTS=ON",
        "-DREALM_CPP_NO_TESTS=ON",
        f"-DOSU_STUFF_BUILD_TESTS={'ON' if build_tests else 'OFF'}",
        f"-DCMAKE_BUILD_TYPE={cmake_type}",
        f"-DOUTPUT_NAME={BINARY_NAME}",
        f"-DUSE_VENDORED_SDL={'ON' if use_vendored_sdl else 'OFF'}",
    ]

    if IS_CI and SYSTEM != "Windows":
        cmd.extend([
            "-DCMAKE_C_COMPILER_LAUNCHER=sccache",
            "-DCMAKE_CXX_COMPILER_LAUNCHER=sccache"
        ])

    return cmd

def read_cached_build_type() -> str | None:
    cache = BUILD_DIR / "CMakeCache.txt"
    if not cache.exists():
        return None

    for line in cache.read_text(errors="replace").splitlines():
        if line.startswith("CMAKE_BUILD_TYPE:STRING="):
            return line.split("=", 1)[1].strip().lower()

    return None

def read_cached_build_tests() -> bool | None:
    cache = BUILD_DIR / "CMakeCache.txt"
    if not cache.exists():
        return None

    for line in cache.read_text(errors="replace").splitlines():
        if line.startswith("OSU_STUFF_BUILD_TESTS:BOOL="):
            return line.split("=", 1)[1].strip().upper() == "ON"

    return None

def is_build_configured() -> bool:
    cache = BUILD_DIR / "CMakeCache.txt"
    if not cache.exists():
        return False

    if not (BUILD_DIR / "build.ninja").exists():
        return False

    return True

def get_vcvarsall_script() -> Path | None:
    candidates = [
        Path("C:/Program Files/Microsoft Visual Studio/2022/Enterprise/VC/Auxiliary/Build/vcvarsall.bat"),
        Path("C:/Program Files/Microsoft Visual Studio/2022/Professional/VC/Auxiliary/Build/vcvarsall.bat"),
        Path("C:/Program Files/Microsoft Visual Studio/2022/Community/VC/Auxiliary/Build/vcvarsall.bat"),
        Path("C:/Program Files (x86)/Microsoft Visual Studio/2022/BuildTools/VC/Auxiliary/Build/vcvarsall.bat"),
    ]

    vswhere = Path("C:/Program Files (x86)/Microsoft Visual Studio/Installer/vswhere.exe")
    if vswhere.exists():
        _, stdout = run([
            str(vswhere),
            "-latest",
            "-products",
            "*",
            "-requires",
            "Microsoft.VisualStudio.Component.VC.Tools.x86.x64",
            "-property",
            "installationPath",
        ], check=False, capture=True)
        installation_path = stdout.strip()
        if installation_path:
            candidates.insert(0, Path(installation_path) / "VC/Auxiliary/Build/vcvarsall.bat")

    for candidate in candidates:
        if candidate.exists():
            return candidate

    return None

def load_msvc_env() -> dict:
    env = os.environ.copy()
    vcvarsall = get_vcvarsall_script()

    if vcvarsall is None:
        print("[ez] vcvarsall.bat not found")
        sys.exit(1)

    _, stdout = run(f'"{str(vcvarsall)}" x64 && set', capture=True)

    for line in stdout.splitlines():
        if "=" not in line:
            continue

        key, value = line.split("=", 1)
        env[key] = value

    return env

def init() -> int:
    print("[ez] initializing submodules...")

    if Path(".gitmodules").exists() and run("git submodule update --init --recursive", check=False)[0] != 0:
        print("[ez] failed to initialize submodules")
        return 1

    tool_exists("cmake")
    tool_exists("ninja")

    if SYSTEM == "Windows":
        if get_vcvarsall_script() is None:
            print("[ez] vcvarsall.bat not found")
            return 1
    else:
        tool_exists("clang")

    return 0

def format_code() -> None:
    _ = run("clang-format -i $(rg --files -g '*.{h,hpp,cpp,cc,cxx}' src)")[0]
    _ = run("clang-format -i $(rg --files -g '*.{h,hpp,cpp,cc,cxx}' tests)")[0]

def clean() -> int:
    if not BUILD_DIR.exists():
        print("[ez] build directory doesn't exist")
        return 0

    print("[ez] removing build directory...")

    try:
        shutil.rmtree(BUILD_DIR)
        return 0
    except PermissionError:
        print("[ez] permission denied")
        return 1

def has_test_data() -> bool:
    return all(marker.exists() for marker in (
        TEST_DATA_CACHE_DIR / "osu" / "osu!.db",
        TEST_DATA_CACHE_DIR / "osu" / "collection.db",
        TEST_DATA_CACHE_DIR / "lazer" / "client.realm",
    ))

def resolve_test_data_source(root: Path) -> Path:
    candidates = (
        root / "tests" / ".data",
        root / ".data",
        root / "data",
    )

    for candidate in candidates:
        if candidate.exists():
            return candidate

    return root

def download_test_data() -> None:
    test_archive_dir = TESTS_BUILD_DIR / "test-downloads"
    test_archive_path = test_archive_dir / "data.tar.gz"
    print(f"[ez] downloading test data from {TEST_DATA_URL}")
    test_archive_dir.mkdir(parents=True, exist_ok=True)
    urllib.request.urlretrieve(TEST_DATA_URL, test_archive_path)

def extract_test_data() -> None:
    test_archive_path = TESTS_BUILD_DIR / "test-downloads" / "data.tar.gz"
    test_extract_dir = TESTS_BUILD_DIR / "data.extract"
    if test_extract_dir.exists():
        shutil.rmtree(test_extract_dir)

    test_extract_dir.mkdir(parents=True, exist_ok=True)

    with tarfile.open(test_archive_path, "r:gz") as archive:
        archive.extractall(test_extract_dir)

    source_dir = resolve_test_data_source(test_extract_dir)

    if TEST_DATA_CACHE_DIR.exists():
        shutil.rmtree(TEST_DATA_CACHE_DIR)

    shutil.move(str(source_dir), str(TEST_DATA_CACHE_DIR))
    shutil.rmtree(test_extract_dir)

def ensure_test_data() -> None:
    test_archive_path = TESTS_BUILD_DIR / "test-downloads" / "data.tar.gz"
    if has_test_data():
        return

    if not test_archive_path.exists():
        download_test_data()

    extract_test_data()

    if not has_test_data():
        print("[ez] test data is invalid after extraction...")
        sys.exit(1)

def prepare_test_runtime_data() -> None:
    test_data_dir = TESTS_BUILD_DIR / "data"
    test_temp_dir = TESTS_BUILD_DIR / "temp"
    if test_data_dir.exists():
        shutil.rmtree(test_data_dir)

    if test_temp_dir.exists():
        shutil.rmtree(test_temp_dir)

    shutil.copytree(TEST_DATA_CACHE_DIR, test_data_dir)
    test_temp_dir.mkdir(parents=True, exist_ok=True)

def cleanup_test_runtime_data() -> None:
    test_data_dir = TESTS_BUILD_DIR / "data"
    test_temp_dir = TESTS_BUILD_DIR / "temp"
    if test_data_dir.exists():
        shutil.rmtree(test_data_dir)

    if test_temp_dir.exists():
        shutil.rmtree(test_temp_dir)

def configure_linux(build_type: str, build_tests: bool = False, use_vendored_sdl: bool = False) -> int:
    cache = BUILD_DIR / "CMakeCache.txt"

    if cache.exists():
        cache.unlink()

    BUILD_DIR.mkdir(exist_ok=True)
    cmd = build_configure_cmd(build_type, build_tests, use_vendored_sdl)
    cmd.extend([
        "-DCMAKE_C_COMPILER=clang",
        "-DCMAKE_CXX_COMPILER=clang++",
    ])
    return run(cmd)[0]

def configure_windows(build_type: str, build_tests: bool = False, use_vendored_sdl: bool = False) -> int:
    cache = BUILD_DIR / "CMakeCache.txt"
    env = load_msvc_env()

    if cache.exists():
        cache.unlink()

    BUILD_DIR.mkdir(exist_ok=True)
    cmd = build_configure_cmd(build_type, build_tests, use_vendored_sdl)
    return run(cmd, env=env)[0]

def configure(build_type: str, target_platform: str, build_tests: bool = False) -> int:
    is_windows = target_platform == "windows" or (target_platform == "auto" and SYSTEM == "Windows")
    is_linux   = target_platform == "linux"   or (target_platform == "auto" and SYSTEM == "Linux")
    use_vendored_sdl = should_use_vendored_sdl(target_platform)

    if is_windows:
        return configure_windows(build_type, build_tests, use_vendored_sdl)

    if is_linux:
        return configure_linux(build_type, build_tests, use_vendored_sdl)

    print(f"[ez] unsupported platform: {SYSTEM}")
    return 1

def build(build_type: str | None) -> int:
    cached_build_type = read_cached_build_type()
    cached_build_tests = read_cached_build_tests()
    selected_build_type = build_type or cached_build_type or "release"
    should_build_tests = selected_build_type == "debug"

    if not is_build_configured():
        if configure(selected_build_type, "auto", build_tests=should_build_tests) != 0:
            return 1
    elif (
        selected_build_type != cached_build_type
        or cached_build_tests is None
        or cached_build_tests != should_build_tests
    ):
        if configure(selected_build_type, "auto", build_tests=should_build_tests) != 0:
            return 1

    env = load_msvc_env() if SYSTEM == "Windows" else None
    code, _ = run([
        "cmake",
        "--build",
        str(BUILD_DIR),
        "--parallel",
        str(get_cpu_count()),
    ], env=env)

    prepare_resources()
    return code

def prepare_flatpak_assets() -> None:
    shutil.copy2(CWD / "resources" / "icons" / "icon.png", CWD / "flatpak" / f"{FLATPAK_APP_ID}.png")

def package_flatpak() -> int:
    DIST_DIR.mkdir(exist_ok=True)
    prepare_flatpak_assets()

    build_code, _ = run([
        "flatpak-builder",
        f"--repo={str(FLATPAK_REPO_DIR)}",
        "--force-clean",
        "--delete-build-dirs",
        "--state-dir",
        str(FLATPAK_STATE_DIR),
        str(FLATPAK_BUILD_DIR),
        str(FLATPAK_MANIFEST_PATH)
    ], check=False)

    if build_code != 0:
        return build_code

    bundle_code, _ = run([
        "flatpak",
        "build-bundle",
        str(FLATPAK_REPO_DIR),
        str(FLATPAK_BUNDLE_PATH),
        FLATPAK_APP_ID
    ], check=False)

    return bundle_code

def package(package_type: str | None) -> int:
    selected_package_type = package_type or "flatpak"

    if selected_package_type == "flatpak":
        return package_flatpak()

    if selected_package_type == "inno":
        print("[ez] not implemented yet")
        return 1

    if selected_package_type == "portable":
        print("[ez] not implemented yet")
        return 1

    print(f"[ez] unsupported package type: {selected_package_type}")
    return 1

def prepare_resources():
    shutil.copytree(CWD / "resources", BUILD_DIR / "resources", dirs_exist_ok=True)

def run_binary() -> int:
    candidates: list[Path] = []

    if SYSTEM == "Linux":
        candidates = [BUILD_DIR / BINARY_NAME, BUILD_DIR / f"{BINARY_NAME}.exe"]
    elif SYSTEM == "Windows":
        candidates = [
            BUILD_DIR / f"{BINARY_NAME}.exe",
            BUILD_DIR / "Release" / f"{BINARY_NAME}.exe",
            BUILD_DIR / "Debug"   / f"{BINARY_NAME}.exe",
        ]
    else:
        print(f"[ez] unsupported platform: {SYSTEM}")
        return 1

    binary = next((p for p in candidates if p.exists()), None)

    if binary is None:
        print("[ez] binary not found")
        return 1

    return run(str(binary))[0]

def run_tests(build_type: str | None) -> int:
    selected_build_type = build_type or read_cached_build_type() or "release"

    if configure(selected_build_type, "auto", build_tests=True) != 0:
        return 1

    env = load_msvc_env() if SYSTEM == "Windows" else None
    code, _ = run([
        "cmake",
        "--build",
        str(BUILD_DIR),
        "--parallel",
        str(get_cpu_count()),
    ], env=env)

    if code != 0:
        return 1

    ensure_test_data()
    prepare_test_runtime_data()

    cached = read_cached_build_type()
    cmd = [
        "ctest",
        "--test-dir",
        str(BUILD_DIR),
        "--output-on-failure",
    ]

    if cached is not None:
        cmd.extend(["-C", "Debug" if cached == "debug" else "Release"])

    try:
        return run(cmd, env=env)[0]
    finally:
        cleanup_test_runtime_data()

def main() -> None:
    parser = argparse.ArgumentParser(description="build script for c++ projects")

    parser.add_argument("command", choices=["init", "configure", "format", "build", "package", "clean", "run", "test"])
    parser.add_argument("--type", choices=["debug", "release"], default=None, dest="build_type")
    parser.add_argument("--package-type", choices=["flatpak", "inno", "portable"], default=None, dest="package_type")
    parser.add_argument("--platform", choices=["auto", "linux", "windows"], default="auto")
    parser.add_argument("--run", action="store_true")

    args = parser.parse_args()

    commands = {
        "init":      init,
        "configure": lambda: configure(
            args.build_type or "release",
            args.platform,
            build_tests=(args.build_type or "release") == "debug",
        ),
        "build":     lambda: build(args.build_type),
        "package":   lambda: package(args.package_type),
        "format":    format_code,
        "clean":     clean,
        "run":       run_binary,
        "test":      lambda: run_tests(args.build_type),
    }

    exit_code = commands[args.command]()

    if args.command == "build" and exit_code == 0 and args.run:
        exit_code = run_binary()

    sys.exit(exit_code)

if __name__ == "__main__":
    main()
