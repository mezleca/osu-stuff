{
    "name": "osu-stuff",
    "version": "2.2.0",
    "description": "yet another osu! manager",
    "homepage": "https://github.com/mezleca/osu-stuff",
    "main": "out/main/index.js",
    "author": "rel",
    "scripts": {
        "format": "prettier --plugin prettier-plugin-svelte --write .",
        "cli": "bun run ./scripts/cli.js",
        "start": "bun run rebuild && bun run cli --build && electron .",
        "dev": "bun run rebuild && bun run cli --watch",
        "test": "cross-env NODE_ENV=test vitest",
        "test:osu": "cross-env NODE_ENV=test vitest ./tests/main/",
        "build": "bun run cli --build",
        "rebuild": "bun x electron-rebuild",
        "postinstall": "electron-builder install-app-deps",
        "build:unpack": "bun run build && electron-builder --dir",
        "build:win": "bun run build && electron-builder --win",
        "build:linux": "bun run build && electron-builder --linux"
    },
    "dependencies": {
        "@electron-toolkit/preload": "^3.0.2",
        "@electron-toolkit/utils": "^4.0.0",
        "adm-zip": "^0.5.16",
        "better-sqlite3": "github:neoxpert/better-sqlite3#896573e3f5c65b88c6c5e01cd040c353e4bfb80c",
        "bun-types": "^1.3.2",
        "osu-api-extended": "^3.1.7",
        "realm": "^20.2.0"
    },
    "devDependencies": {
        "@electron-toolkit/eslint-config": "^2.1.0",
        "@electron/rebuild": "^4.0.1",
        "@sveltejs/vite-plugin-svelte": "^6.2.1",
        "@types/bun": "latest",
        "electron": "^39.1.1",
        "electron-builder": "^26.0.12",
        "node-addon-api": "^8.5.0",
        "node-api-headers": "^1.6.0",
        "prettier": "^3.6.2",
        "prettier-plugin-svelte": "^3.4.0",
        "svelte": "^5.39.11",
        "vite": "^7.1.9",
        "vitest": "^4.0.8",
        "vite-tsconfig-paths": "^5.1.4",
        "cross-env": "^10.1.0",
        "@types/better-sqlite3": "^7.6.13"
    },
    "private": false,
    "peerDependencies": {
        "typescript": "^5"
    }
}
