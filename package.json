{
    "name": "osu-stuff",
    "version": "2.5.12",
    "description": "yet another osu! manager",
    "homepage": "https://github.com/mezleca/osu-stuff",
    "main": "./out/main/index.js",
    "license": "MIT",
    "author": "rel",
    "scripts": {
        "format": "prettier --plugin prettier-plugin-svelte --write .",
        "lint": "bun run lint:node && bun run lint:web && bun run lint:test",
        "lint:node": "bunx tsc --noEmit -p tsconfig.node.json --tsBuildInfoFile out/tsc-node.tsbuildinfo",
        "lint:web": "bunx tsc --noEmit -p tsconfig.web.json --tsBuildInfoFile out/tsc-web.tsbuildinfo",
        "lint:test": "bunx tsc --noEmit -p tsconfig.test.json --tsBuildInfoFile out/tsc-test.tsbuildinfo",
        "svelte-check": "svelte-check --tsconfig ./tsconfig.json",
        "start": "bun rebuild && bun scripts/cli.ts start",
        "dev": "bun rebuild && bun scripts/cli.ts dev",
        "build": "bun rebuild && bun scripts/cli.ts build",
        "rebuild": "electron-rebuild -f",
        "postinstall": "electron-builder install-app-deps",
        "test": "cross-env NODE_ENV=test vitest ./tests/main/",
        "test:clients": "cross-env NODE_ENV=test vitest ./tests/main/clients.test.ts",
        "test:processor": "cross-env NODE_ENV=test vitest ./tests/main/processor.test.ts",
        "build:unpack": "bun run build && electron-builder --dir",
        "build:win": "bun run build && electron-builder --win",
        "build:linux": "bun run build && electron-builder --linux"
    },
    "dependencies": {
        "@electron-toolkit/utils": "^4.0.0",
        "@rel-packages/audio-utils": "^0.2.0",
        "@rel-packages/osu-beatmap-parser": "^1.5.6",
        "@rel-packages/osu-beatmap-preview": "0.12.1",
        "archiver": "^7.0.1",
        "better-sqlite3": "^12.6.2",
        "chroma-js": "^3.2.0",
        "electron-updater": "^6.8.3",
        "ms": "^2.1.3",
        "osu-api-extended": "^3.1.8",
        "quick-lru": "^7.3.0",
        "realm": "^20.2.0"
    },
    "devDependencies": {
        "@sveltejs/vite-plugin-svelte": "^7.0.0",
        "@electron-toolkit/eslint-config-prettier": "^3.0.0",
        "@electron-toolkit/eslint-config-ts": "^3.1.0",
        "@electron-toolkit/preload": "^3.0.2",
        "@electron-toolkit/tsconfig": "^2.0.0",
        "@types/better-sqlite3": "^7.6.13",
        "@types/bun": "^1.3.1",
        "@types/jszip": "^3.4.1",
        "@types/node": "^25.0.1",
        "@types/archiver": "^7.0.0",
        "@types/chroma-js": "^3.1.2",
        "cross-env": "^10.1.0",
        "electron": "^41.0.2",
        "electron-builder": "^26.8.1",
        "prettier": "^3.8.1",
        "prettier-plugin-svelte": "^3.5.0",
        "svelte": "^5.53.7",
        "svelte-check": "^4.4.4",
        "svelte-preprocess": "6.0.3",
        "typescript": "^5.9.3",
        "vite": "8.0.0-beta.18",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.0.18"
    }
}
