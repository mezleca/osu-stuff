{
    "name": "osu-clients",
    "version": "0.0.0",
    "description": "native osu! clients bridge for osu-stuff",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist",
        "src/native",
        "CMakeLists.txt"
    ],
    "scripts": {
        "build:native": "bun scripts/build.ts",
        "build:ts": "bunx tsc -p tsconfig.json",
        "build": "bun run build:native && bun run build:ts"
    },
    "dependencies": {
        "koffi": "^2.14.1"
    },
    "devDependencies": {
        "@types/bun": "^1.3.13",
        "@types/node": "^25.0.1",
        "typescript": "^6.0.2"
    }
}
