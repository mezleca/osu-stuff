{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "declaration": true,
        "outDir": "dist",
        "rootDir": "ts",
        "strict": true,
        "verbatimModuleSyntax": true,
        "skipLibCheck": true,
        "types": ["bun"]
    },
    "include": ["ts/*.ts", "scripts/*.ts", "tests/*.ts"],
    "exclude": ["build/**", "dist/**"]
}
